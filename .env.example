# ────────────────────────────────────────────────────────────────
# Deepgram  —  https://console.deepgram.com
# ────────────────────────────────────────────────────────────────

# Your Deepgram API key (from Console → API Keys)
DEEPGRAM_API_KEY=

# Your Deepgram Project ID (from Console → Settings)
# Optional but recommended — enables short-lived browser tokens
DEEPGRAM_PROJECT_ID=

# Set to "true" to mint short-lived browser tokens.
# Default behavior (unset/false) uses DEEPGRAM_API_KEY directly for maximum reliability.
# DEEPGRAM_USE_EPHEMERAL=true

# ────────────────────────────────────────────────────────────────
# AWS  —  https://console.aws.amazon.com
# ────────────────────────────────────────────────────────────────

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only needed for temporary credentials

# Bedrock model — Llama 3.3 70B is the default
# Other options: meta.llama3-1-8b-instruct-v1:0 (faster/cheaper)
BEDROCK_MODEL_ID=meta.llama3-3-70b-instruct-v1:0

# Polly voice — Neural engine voices:
# US: Joanna, Matthew, Aria, Stephen
# UK: Emma, Brian, Amy
POLLY_VOICE_ID=Joanna

# ────────────────────────────────────────────────────────────────
# Google Calendar  —  https://console.cloud.google.com
# ────────────────────────────────────────────────────────────────

# Entire service-account JSON key as a single line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Calendar to add events to — "primary" or a specific calendar ID
GOOGLE_CALENDAR_ID=primary

# ────────────────────────────────────────────────────────────────
# Local dev overrides
# ────────────────────────────────────────────────────────────────

# Set to "ollama" to use a local Ollama model instead of Bedrock
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
